{
  "manifest_version": 3,
  "name": "Bathyal Lens",
  "version": "1.0.0",
  "description": "See beneath the surface. BYOK Chrome extension that analyzes AI-generated answers — revealing citation patterns, ghost sources, and structural insights using your own Claude API key.",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://www.google.com/*",
    "https://www.perplexity.ai/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.perplexity.ai/*"
      ],
      "js": [
        "platforms/google.js",
        "platforms/perplexity.js",
        "overlay/styles.js",
        "overlay/components.js",
        "overlay/panel.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/bathyal-16.png",
      "32": "icons/bathyal-32.png",
      "48": "icons/bathyal-48.png",
      "128": "icons/bathyal-128.png"
    }
  },
  "icons": {
    "16": "icons/bathyal-16.png",
    "32": "icons/bathyal-32.png",
    "48": "icons/bathyal-48.png",
    "128": "icons/bathyal-128.png"
  }
}
